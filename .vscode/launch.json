{
  "version": "0.2.0",
  "configurations": [
    {
      "name": "Run MCP Server",
      "type": "lldb",
      "request": "launch",
      "cargo": {
        "command": "run"
      },
      "cwd": "${workspaceFolder}/crates/mcp"
    },
    {
      "name": "Run MCP (with github)",
      "type": "lldb",
      "request": "launch",
      "cargo": {
        "command": "run",
        "args": ["--features", "github"]
      },
      "cwd": "${workspaceFolder}/crates/mcp"
    }
  ]
}
